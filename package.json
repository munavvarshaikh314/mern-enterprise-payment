{
  "name": "mern-backend",
  "version": "1.0.0",
  "description": "Full-stack MERN application backend with JWT auth, 2FA, payments, and analytics",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts,js --exec ts-node src/server.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "postbuild": "node -e \"const fs=require('fs'); if(fs.existsSync('src/templates')){fs.cpSync('src/templates','dist/templates',{recursive:true});}\""
  },
  "keywords": [
    "mern",
    "typescript",
    "express",
    "mongodb",
    "jwt",
    "2fa",
    "razorpay",
    "analytics"
  ],
  "author": "CSE Student",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "express-slow-down": "^3.0.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.0.0",
    "isomorphic-dompurify": "^2.35.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.15.0",
    "pg": "^8.17.2",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "razorpay": "^2.9.6",
    "redis": "^5.10.0",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.19",
    "@types/pdfkit": "^0.13.5",
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
